{
  "name": "@verevoir/context",
  "version": "0.11.2",
  "description": "In-process content + symbol cache for LLM context windows. Keyed (source, version, item). Tree-sitter symbol extraction + grep + cached-read bridge as subpath imports.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./code": {
      "types": "./dist/code/index.d.ts",
      "import": "./dist/code/index.js"
    },
    "./github": {
      "types": "./dist/github/index.d.ts",
      "import": "./dist/github/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "import": "./dist/fs/index.js"
    },
    "./notion": {
      "types": "./dist/notion/index.d.ts",
      "import": "./dist/notion/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "peerDependencies": {
    "@verevoir/sources": "*",
    "@verevoir/workflows": "*",
    "tree-sitter": "*",
    "tree-sitter-c": "*",
    "tree-sitter-c-sharp": "*",
    "tree-sitter-cpp": "*",
    "tree-sitter-go": "*",
    "tree-sitter-java": "*",
    "tree-sitter-javascript": "*",
    "tree-sitter-python": "*",
    "tree-sitter-scala": "*",
    "tree-sitter-typescript": "*"
  },
  "peerDependenciesMeta": {
    "@verevoir/sources": {
      "optional": true
    },
    "@verevoir/workflows": {
      "optional": true
    },
    "tree-sitter": {
      "optional": true
    },
    "tree-sitter-c": {
      "optional": true
    },
    "tree-sitter-c-sharp": {
      "optional": true
    },
    "tree-sitter-cpp": {
      "optional": true
    },
    "tree-sitter-go": {
      "optional": true
    },
    "tree-sitter-java": {
      "optional": true
    },
    "tree-sitter-javascript": {
      "optional": true
    },
    "tree-sitter-python": {
      "optional": true
    },
    "tree-sitter-scala": {
      "optional": true
    },
    "tree-sitter-typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@verevoir/sources": "^0.6.0",
    "@verevoir/workflows": "^0.5.0",
    "prettier": "^3",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "0.23.2",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "0.23.2",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.4",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^5",
    "vitest": "^4"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/verevoir/context.git"
  },
  "engines": {
    "node": ">=20"
  }
}
